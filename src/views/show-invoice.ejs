<%- include('header', { pageTitle: 'Invoice ' + invoice.invoice_number, currentPage: 'invoices' }) %>

<div class="page-title">INVOICE DETAILS</div>
<div class="page-subtitle">Invoice Overview — Document ID: <span style="color: var(--accent); font-weight: 800;"><%= invoice.invoice_number %></span></div>

<!-- Action Controls -->
<div class="print-hide" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 48px;">
  <a href="/" class="btn btn-ghost" style="border-radius: 12px; font-weight: 800;">
    <i class="fa-solid fa-arrow-left-long"></i> BACK
  </a>
  <div style="display: flex; gap: 16px; align-items: center;">
    <div class="badge badge-<%= invoice.status.toLowerCase() %>" style="padding: 10px 20px; border-radius: 12px; background: var(--bg-card); backdrop-filter: blur(10px);">
      <div style="width: 8px; height: 8px; background: var(--<%= invoice.status.toLowerCase() %>); border-radius: 50%; box-shadow: 0 0 10px var(--<%= invoice.status.toLowerCase() %>);"></div>
      <span style="font-size: 0.85rem; font-weight: 900; text-transform: uppercase; color: #fff;"><%= invoice.status %></span>
    </div>
    <a href="/invoices/<%= invoice.invoice_uuid %>/edit" class="btn btn-secondary" style="padding: 14px 24px; font-weight: 900; border-radius: 12px;">
      <i class="fa-solid fa-pen-to-square"></i> EDIT
    </a>
    <button class="btn btn-ghost" onclick="if(confirm('Are you sure you want to delete this invoice? This action cannot be undone.')) { document.getElementById('delete-form').submit(); }" style="padding: 14px 24px; color: var(--error);">
      <i class="fa-solid fa-trash-can"></i>
    </button>
    <form id="delete-form" action="/invoices/<%= invoice.invoice_uuid %>/delete" method="POST" style="display: none;"></form>
    <button class="btn btn-ghost" onclick="window.print()" style="padding: 14px 24px;">
      <i class="fa-solid fa-print"></i>
    </button>
    <a href="/invoices/<%= invoice.invoice_uuid %>/pdf" class="btn btn-primary" style="padding: 14px 32px; font-weight: 900; display: inline-flex; align-items: center; justify-content: center;">
      <i class="fa-solid fa-file-pdf"></i> DOWNLOAD PDF
    </a>
  </div>
</div>

<!-- Digital Invoice Document -->
<div class="invoice-doc" style="max-width: 1000px; margin: 0 auto; background: #fff; color: #1a1a1a;">
  
  <!-- Header Section -->
  <div class="doc-header">
    <div>
      <div class="doc-brand">Freight<span>Ledger</span></div>
      <div style="font-family:var(--font-mono); font-size:10px; color:rgba(255,255,255,0.6); letter-spacing:0.15em; margin-top:10px; text-transform:uppercase; font-weight:800">
        Professional Logistics Billing System
      </div>
    </div>
    <div style="text-align:right">
      <div style="font-size: 0.75rem; font-weight: 900; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em;">Invoice Number</div>
      <div class="doc-title" style="font-size: 48px;"><%= invoice.invoice_number %></div>
      <div style="font-family:var(--font-mono); font-size:11px; color:rgba(255,255,255,0.7); letter-spacing:0.1em; margin-top:8px; font-weight:700">DATE: <%= new Date(invoice.issue_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase() %></div>
    </div>
  </div>

  <!-- Parties Block -->
  <div class="invoice-parties">
    <div class="party-block">
      <div class="party-label">BILL TO</div>
      <div class="party-name" style="font-size: 1.5rem;"><%= invoice.receiver_name || 'Miscellaneous Client' %></div>
      <div style="font-family:var(--font-mono); font-size:12px; color:#475569; line-height:1.7; letter-spacing:0.02em; white-space:pre-line; margin-top:12px; font-weight:600">
        <%= invoice.receiver_address || 'No address provided.' %>
      </div>
    </div>
    <div class="party-block" style="text-align: right;">
      <div class="party-label">BILL FROM</div>
      <div class="party-name" style="font-size: 1.5rem;"><%= invoice.sender_name %></div>
      <div style="font-family:var(--font-mono); font-size:12px; color:#475569; line-height:1.8; letter-spacing:0.02em; white-space:pre-line; margin-top:12px; font-weight:600">
        <%= invoice.sender_address %>
      </div>
    </div>
  </div>

  <!-- Transport Particulars -->
  <div class="transport-particulars" style="border-top: 1px solid #e2e8f0;">
    <div style="font-family:var(--font-mono); font-size:10px; color:var(--accent); letter-spacing:0.2em; text-transform:uppercase; margin-bottom:24px; font-weight:900">Operational Details</div>
    <div class="tp-grid">
      <div>
        <div style="font-family:var(--font-mono); font-size:10px; color:#94a3b8; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:6px; font-weight:800">Route</div>
        <div style="font-family:var(--font-mono); font-size:14px; font-weight:900; color:#000;">
          <% if (invoice.particulars_source && invoice.particulars_destination) { %>
            <%= invoice.particulars_source.toUpperCase() %> <span style="color:var(--accent)">→</span> <%= invoice.particulars_destination.toUpperCase() %>
          <% } else { %>
            UNDEFINED
          <% } %>
        </div>
      </div>
      <div>
        <div style="font-family:var(--font-mono); font-size:10px; color:#94a3b8; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:6px; font-weight:800">Transit ID</div>
        <div style="font-family:var(--font-mono); font-size:14px; font-weight:900; color:#000;"><%= invoice.challan_no || 'N/A' %></div>
      </div>
    </div>

    <!-- Dynamic Vehicle Table -->
    <% if (invoice.vehicle_entries && invoice.vehicle_entries.length > 0) { %>
      <div style="margin-top:40px; border-top: 1px solid #e2e8f0; padding-top:24px">
        <table style="width:100%;">
          <thead>
            <tr>
              <th style="padding:12px 0; text-align:left; font-family:var(--font-mono); font-size:10px; color:#94a3b8; text-transform:uppercase; border:none; background:none; font-weight:800;">Registration Number</th>
              <th style="padding:12px 0; text-align:left; font-family:var(--font-mono); font-size:10px; color:#94a3b8; text-transform:uppercase; border:none; background:none; font-weight:800;">Type</th>
              <th style="padding:12px 0; text-align:left; font-family:var(--font-mono); font-size:10px; color:#94a3b8; text-transform:uppercase; border:none; background:none; font-weight:800;">Size</th>
              <th style="padding:12px 0; text-align:right; font-family:var(--font-mono); font-size:10px; color:#94a3b8; text-transform:uppercase; border:none; background:none; font-weight:800;">Load Type</th>
            </tr>
          </thead>
          <tbody>
            <% invoice.vehicle_entries.forEach(entry => { %>
              <tr style="border-bottom: 1px solid #f1f5f9;">
                <td style="padding:14px 0; font-family:var(--font-mono); font-size:12px; color:#000; font-weight:900;"><%= entry.registration %></td>
                <td style="padding:14px 0; font-family:var(--font-mono); font-size:12px; color:#475569; font-weight:700;"><%= entry.vehicle_type || '—' %></td>
                <td style="padding:14px 0; font-family:var(--font-mono); font-size:12px; color:#475569; font-weight:700;"><%= entry.vehicle_size || '—' %></td>
                <td style="padding:14px 0; font-family:var(--font-mono); font-size:12px; color:#000; font-weight:900; text-align:right;"><%= entry.load_type || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Financial Matrix -->
  <div style="padding:48px 80px 0; background: #fff;">
    <div style="font-size: 0.85rem; font-weight: 950; text-transform: uppercase; color: #1a1a1a; letter-spacing: 0.2em; margin-bottom: 32px; border-bottom: 3px solid #000; padding-bottom: 12px; display: inline-block;">Billing Summary</div>
    <table style="width:100%;">
      <thead>
        <tr>
          <th style="padding:16px 0; text-align:left; font-family:var(--font-mono); font-size:11px; color:#000; text-transform:uppercase; border-bottom:2px solid #000; background:none; font-weight:900;">Description</th>
          <th style="padding:16px 0; text-align:right; font-family:var(--font-mono); font-size:11px; color:#000; text-transform:uppercase; border-bottom:2px solid #000; background:none; font-weight:900;">Count</th>
          <th style="padding:16px 0; text-align:right; font-family:var(--font-mono); font-size:11px; color:#000; text-transform:uppercase; border-bottom:2px solid #000; background:none; font-weight:900;">Unit Price</th>
          <th style="padding:16px 0; text-align:right; font-family:var(--font-mono); font-size:11px; color:#000; text-transform:uppercase; border-bottom:2px solid #000; background:none; font-weight:900;">Total</th>
        </tr>
      </thead>
      <tbody>
        <% if (invoice.vehicle_rates && invoice.vehicle_rates.length > 0) { %>
          <% invoice.vehicle_rates.slice().sort((a, b) => b.vehicles - a.vehicles).forEach((rate, index) => { %>
            <tr style="border-bottom: 1px solid #f1f5f9;">
              <td style="padding:28px 0;">
                <% if (index === 0) { %>
                  <div style="font-weight:900; color:#000; font-size:16px; letter-spacing: -0.01em;">Transportation Rate</div>
                <% } else { %>
                  <div style="font-size:16px; line-height:1; visibility:hidden;">Transportation Rate</div>
                <% } %>
                <div style="font-family:var(--font-mono); font-size:11px; color:#94a3b8; margin-top:6px; font-weight:800; text-transform:uppercase; letter-spacing: 0.05em;">Vehicles: <%= rate.vehicles %></div>
              </td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; font-weight:800; color:#475569;"><%= rate.vehicles %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; color:#475569;"><%= FinanceService.formatCurrency(rate.rate_per_vehicle) %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:16px; font-weight:900; color:#000;"><%= FinanceService.formatCurrency(rate.amount) %></td>
            </tr>
          <% }) %>
        <% } %>

        <% if (invoice.demurrage_entries && invoice.demurrage_entries.length > 0) { %>
          <% invoice.demurrage_entries.slice().sort((a, b) => b.vehicles - a.vehicles).forEach((dem, index) => { %>
            <tr style="border-bottom: 1px solid #f1f5f9;">
              <td style="padding:28px 0;">
                <% if (index === 0) { %>
                  <div style="font-weight:900; color:#000; font-size:16px; letter-spacing: -0.01em;">Demurrage Rate</div>
                <% } else { %>
                  <div style="font-size:16px; line-height:1; visibility:hidden;">Demurrage Rate</div>
                <% } %>
                <div style="font-family:var(--font-mono); font-size:11px; color:#94a3b8; margin-top:6px; font-weight:800; text-transform:uppercase; letter-spacing: 0.05em;">Vehicles: <%= dem.vehicles %>, Days: <%= dem.days %></div>
              </td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; font-weight:800; color:#475569;"><%= dem.vehicles %> × <%= dem.days %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; color:#475569;"><%= FinanceService.formatCurrency(dem.rate) %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:16px; font-weight:900; color:#000;"><%= FinanceService.formatCurrency(dem.amount) %></td>
            </tr>
          <% }) %>
        <% } %>

        <% if (invoice.items && invoice.items.length > 0) { %>
          <% invoice.items.forEach(item => { %>
            <tr style="border-bottom: 1px solid #f1f5f9;">
              <td style="padding:28px 0; font-weight:900; color:#000; font-size:16px; letter-spacing: -0.01em;"><%= item.description.toUpperCase() %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; font-weight:800; color:#475569;"><%= item.quantity %> UNITS</td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:14px; color:#475569;"><%= FinanceService.formatCurrency(item.rate) %></td>
              <td style="padding:28px 0; text-align:right; font-family:var(--font-mono); font-size:16px; font-weight:900; color:#000;"><%= FinanceService.formatCurrency(item.amount) %></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Synthesis Summary -->
  <div style="padding:48px 80px 80px; display:flex; justify-content:flex-end; background: #fff;">
    <div style="width:400px">
      <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; font-family:var(--font-mono); font-size:14px; color:#64748b; font-weight:800">
        <span>VALUATION SUBTOTAL</span>
        <span style="color:#1e293b"><%= FinanceService.formatCurrency(invoice.total_amount) %></span>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; margin-top:24px; padding-top:24px; border-top:4px solid #000">
        <span style="font-family:var(--font-display); font-size:24px; font-weight:950; color:#000; text-transform:uppercase; letter-spacing: 0.05em;">Total</span>
        <span style="font-family:var(--font-display); font-size:40px; font-weight:950; color:var(--accent); letter-spacing: -0.04em;"><%= FinanceService.formatCurrency(invoice.total_amount) %></span>
      </div>
    </div>
  </div>

  <!-- Registry Footnotes -->
  <% if (invoice.notes) { %>
    <div style="padding:48px 80px; border-top:1px solid #f1f5f9; background: #f8fafc;">
      <div style="font-family:var(--font-mono); font-size:10px; color:#94a3b8; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:16px; font-weight:900">Notes & Terms</div>
      <p style="font-family:'Instrument Serif', serif; font-style:italic; font-size:18px; color:#334155; line-height:1.9;"><%= invoice.notes %></p>
    </div>
  <% } %>

</div>

<%- include('footer') %>
